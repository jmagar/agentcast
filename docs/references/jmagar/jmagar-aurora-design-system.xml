<file path="public/r/aurora-terminal.json">
{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "aurora-terminal",
  "type": "registry:block",
  "title": "Aurora Terminal",
  "author": "jmagar <https://github.com/jmagar>",
  "description": "Aurora-native terminal with 38px navy titlebar (Labby mark, session name, status dot, kill/clear/run buttons), full color system using Aurora tokens, compact in-chat variant, and blinking cursor.",
  "dependencies": [],
  "registryDependencies": [
    "aurora-tokens",
    "aurora-button"
  ],
  "files": [
    {
      "path": "registry/aurora/blocks/navigation/terminal/terminal.tsx",
      "content": "\"use client\"\n\nimport * as React from \"react\"\nimport { Button } from \"@/registry/aurora/ui/button\"\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface TerminalLine {\n  text: string\n  type?: \"command\" | \"output\" | \"error\" | \"warn\" | \"success\" | \"muted\"\n}\n\nexport interface TerminalProps {\n  lines: TerminalLine[]\n  title?: string\n  status?: \"connected\" | \"idle\" | \"error\"\n  compact?: boolean\n  onKill?: () => void\n  onClear?: () => void\n  onRun?: () => void\n}\n\n// ---------------------------------------------------------------------------\n// Aurora \"Labby\" stacked-plane SVG mark (4 diamond paths, 10px)\n// ---------------------------------------------------------------------------\n\nfunction LabbyMark({ size = 10 }: { size?: number }) {\n  const s = size\n  return (\n    <svg\n      width={s}\n      height={s * 1.4}\n      viewBox=\"0 0 10 14\"\n      fill=\"none\"\n      aria-label=\"Aurora\"\n      style={{ flexShrink: 0 }}\n    >\n      {/* Four stacked diamond planes, slightly offset vertically */}\n      <path d=\"M5 0L9 2.5L5 5L1 2.5Z\" fill=\"var(--aurora-accent-primary)\" opacity=\"0.95\" />\n      <path d=\"M5 3L9 5.5L5 8L1 5.5Z\" fill=\"var(--aurora-accent-primary)\" opacity=\"0.75\" />\n      <path d=\"M5 6L9 8.5L5 11L1 8.5Z\" fill=\"var(--aurora-accent-primary)\" opacity=\"0.5\" />\n      <path d=\"M5 9L9 11.5L5 14L1 11.5Z\" fill=\"var(--aurora-accent-primary)\" opacity=\"0.28\" />\n    </svg>\n  )\n}\n\n// ---------------------------------------------------------------------------\n// Status dot\n// ---------------------------------------------------------------------------\n\nfunction StatusDot({ status }: { status: TerminalProps[\"status\"] }) {\n  const color =\n    status === \"connected\"\n      ? \"var(--aurora-success)\"\n      : status === \"idle\"\n      ? \"var(--aurora-warn)\"\n      : \"var(--aurora-error)\"\n\n  return (\n    <span\n      title={status}\n      style={{\n        display: \"inline-block\",\n        width: \"7px\",\n        height: \"7px\",\n        borderRadius: \"50%\",\n        background: color,\n        boxShadow: `0 0 5px ${color}`,\n        flexShrink: 0,\n      }}\n    />\n  )\n}\n\n// ---------------------------------------------------------------------------\n// Titlebar action buttons (aurora neutral square style)\n// ---------------------------------------------------------------------------\n\nfunction TitlebarButton({\n  children,\n  onClick,\n  title,\n}: {\n  children: React.ReactNode\n  onClick?: () => void\n  title?: string\n}) {\n  return (\n    <Button\n      type=\"button\"\n      variant=\"neutral\"\n      size=\"icon\"\n      onClick={onClick}\n      title={title}\n      style={{\n        width: \"26px\",\n        height: \"22px\",\n        fontSize: \"10px\",\n        fontFamily: \"var(--aurora-font-mono)\",\n      }}\n    >\n      {children}\n    </Button>\n  )\n}\n\n// Three neutral square dots (NOT mac traffic lights)\nfunction WindowDots() {\n  return (\n    <div style={{ display: \"flex\", gap: \"4px\", alignItems: \"center\" }}>\n      {[0, 1, 2].map((i) => (\n        <span\n          key={i}\n          style={{\n            display: \"inline-block\",\n            width: \"8px\",\n            height: \"8px\",\n            borderRadius: \"2px\",\n            background: \"var(--aurora-border-strong)\",\n          }}\n        />\n      ))}\n    </div>\n  )\n}\n\n// ---------------------------------------------------------------------------\n// Line color mapping\n// ---------------------------------------------------------------------------\n\nfunction getLineColor(type: TerminalLine[\"type\"]): string {\n  switch (type) {\n    case \"command\":\n      return \"var(--aurora-accent-primary)\"\n    case \"error\":\n      return \"var(--aurora-error)\"\n    case \"warn\":\n      return \"var(--aurora-warn)\"\n    case \"success\":\n      return \"var(--aurora-success)\"\n    case \"muted\":\n      return \"var(--aurora-text-muted)\"\n    case \"output\":\n    default:\n      return \"var(--aurora-text-primary)\"\n  }\n}\n\nfunction LinePrefix({ type }: { type?: TerminalLine[\"type\"] }) {\n  if (type === \"command\") {\n    return (\n      <span\n        style={{\n          color: \"var(--aurora-accent-strong)\",\n          userSelect: \"none\",\n          marginRight: \"2px\",\n          fontWeight: 600,\n        }}\n      >\n        $\n      </span>\n    )\n  }\n  if (type === \"error\") {\n    return (\n      <span\n        style={{\n          color: \"var(--aurora-error)\",\n          userSelect: \"none\",\n          marginRight: \"2px\",\n        }}\n      >\n        ✗\n      </span>\n    )\n  }\n  if (type === \"success\") {\n    return (\n      <span\n        style={{\n          color: \"var(--aurora-success)\",\n          userSelect: \"none\",\n          marginRight: \"2px\",\n        }}\n      >\n        ✓\n      </span>\n    )\n  }\n  if (type === \"warn\") {\n    return (\n      <span\n        style={{\n          color: \"var(--aurora-warn)\",\n          userSelect: \"none\",\n          marginRight: \"2px\",\n        }}\n      >\n        ⚠\n      </span>\n    )\n  }\n  return null\n}\n\n// ---------------------------------------------------------------------------\n// Full titlebar (38px)\n// ---------------------------------------------------------------------------\n\nfunction Titlebar({\n  title,\n  status,\n  compact,\n  onKill,\n  onClear,\n  onRun,\n}: Pick<TerminalProps, \"title\" | \"status\" | \"compact\" | \"onKill\" | \"onClear\" | \"onRun\">) {\n  return (\n    <div\n      style={{\n        display: \"flex\",\n        alignItems: \"center\",\n        gap: compact ? \"6px\" : \"8px\",\n        padding: compact ? \"0 10px\" : \"0 12px\",\n        height: compact ? \"30px\" : \"38px\",\n        background: \"var(--aurora-panel-strong)\",\n        borderBottom: \"1px solid var(--aurora-border-default)\",\n        boxShadow: \"var(--aurora-highlight-medium)\",\n        flexShrink: 0,\n      }}\n    >\n      {/* Left: Labby mark + session name */}\n      <LabbyMark size={compact ? 8 : 10} />\n      <span\n        style={{\n          fontFamily: \"var(--aurora-font-mono)\",\n          fontSize: compact ? \"11px\" : \"12px\",\n          color: \"var(--aurora-text-muted)\",\n          fontWeight: 500,\n          overflow: \"hidden\",\n          textOverflow: \"ellipsis\",\n          whiteSpace: \"nowrap\",\n          minWidth: 0,\n        }}\n      >\n        {title ?? \"terminal\"}\n      </span>\n\n      {/* Status dot */}\n      <StatusDot status={status ?? \"connected\"} />\n\n      {/* Spacer */}\n      <div style={{ flex: 1 }} />\n\n      {/* Action buttons */}\n      {!compact && (\n        <>\n          {onKill && (\n            <TitlebarButton onClick={onKill} title=\"Kill session\">\n              ×\n            </TitlebarButton>\n          )}\n          {onClear && (\n            <TitlebarButton onClick={onClear} title=\"Clear output\">\n              ⌫\n            </TitlebarButton>\n          )}\n          {onRun && (\n            <TitlebarButton onClick={onRun} title=\"Run\">\n              ▶\n            </TitlebarButton>\n          )}\n        </>\n      )}\n\n      {/* Three neutral square dots */}\n      <WindowDots />\n    </div>\n  )\n}\n\n// ---------------------------------------------------------------------------\n// Main Terminal component\n// ---------------------------------------------------------------------------\n\nexport function Terminal({\n  lines,\n  title,\n  status = \"connected\",\n  compact = false,\n  onKill,\n  onClear,\n  onRun,\n}: TerminalProps) {\n  const bodyRef = React.useRef<HTMLDivElement>(null)\n\n  // Auto-scroll to bottom when lines change\n  React.useEffect(() => {\n    const el = bodyRef.current\n    if (el) {\n      el.scrollTop = el.scrollHeight\n    }\n  }, [lines])\n\n  return (\n    <div\n      style={{\n        display: \"flex\",\n        flexDirection: \"column\",\n        background: \"var(--aurora-page-bg)\",\n        border: \"1px solid var(--aurora-border-default)\",\n        borderRadius: \"var(--aurora-radius-2)\",\n        overflow: \"hidden\",\n        boxShadow: \"var(--aurora-shadow-medium)\",\n        fontFamily: \"var(--aurora-font-mono)\",\n      }}\n    >\n      <Titlebar\n        title={title}\n        status={status}\n        compact={compact}\n        onKill={onKill}\n        onClear={onClear}\n        onRun={onRun}\n      />\n\n      {/* Body */}\n      <div\n        ref={bodyRef}\n        style={{\n          padding: compact ? \"8px 12px\" : \"12px 16px\",\n          overflowY: \"auto\",\n          maxHeight: compact ? \"180px\" : \"420px\",\n          lineHeight: \"1.6\",\n          fontSize: compact ? \"12px\" : \"13px\",\n        }}\n      >\n        {lines.length === 0 && (\n          <div\n            style={{\n              color: \"var(--aurora-text-muted)\",\n              fontStyle: \"italic\",\n              opacity: 0.6,\n            }}\n          >\n            No output\n          </div>\n        )}\n\n        {lines.map((line, i) => (\n          <div\n            key={i}\n            style={{\n              display: \"flex\",\n              alignItems: \"baseline\",\n              gap: \"2px\",\n              color: getLineColor(line.type),\n              ...(line.type === \"error\"\n                ? {\n                    background: \"color-mix(in srgb, var(--aurora-error) 6%, transparent)\",\n                    marginLeft: \"-16px\",\n                    paddingLeft: \"16px\",\n                    marginRight: \"-16px\",\n                    paddingRight: \"16px\",\n                  }\n                : {}),\n            }}\n          >\n            <LinePrefix type={line.type} />\n            <span\n              style={{\n                whiteSpace: \"pre-wrap\",\n                wordBreak: \"break-all\",\n                flex: 1,\n                minWidth: 0,\n              }}\n            >\n              {line.text}\n            </span>\n          </div>\n        ))}\n\n        {/* Blinking cursor at end */}\n        {status === \"connected\" && (\n          <div\n            style={{\n              display: \"inline-flex\",\n              alignItems: \"center\",\n              marginTop: \"2px\",\n            }}\n          >\n            <span style={{ color: \"var(--aurora-accent-primary)\" }}>$ </span>\n            <span\n              style={{\n                display: \"inline-block\",\n                width: \"8px\",\n                height: \"14px\",\n                background: \"var(--aurora-accent-primary)\",\n                opacity: 0.7,\n                marginLeft: \"2px\",\n                borderRadius: \"1px\",\n                animation: \"aurora-cursor-blink 1s step-end infinite\",\n              }}\n            />\n          </div>\n        )}\n      </div>\n\n      <style>{`\n        @keyframes aurora-cursor-blink {\n          0%, 100% { opacity: 0.7; }\n          50% { opacity: 0; }\n        }\n      `}</style>\n    </div>\n  )\n}\n\nexport default Terminal\n",
      "type": "registry:component",
      "target": "@components/aurora/terminal.tsx"
    }
  ],
  "meta": {
    "namespace": "@aurora",
    "style": "aurora",
    "family": "block",
    "requiresTokens": true,
    "sourcePath": "registry/aurora/blocks/navigation/terminal/terminal.tsx",
    "installTarget": "@components/aurora/terminal.tsx",
    "taxonomy": "navigation"
  },
  "docs": "Aurora block that expects `aurora-tokens` to be installed first.\n\nDefault install target: `@components/aurora/terminal.tsx`.\n\nRegistry dependencies: `aurora-tokens`, `aurora-button`.",
  "categories": [
    "aurora",
