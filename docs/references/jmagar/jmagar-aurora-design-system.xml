<file path="public/r/aurora-number-input.json">
{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "aurora-number-input",
  "type": "registry:ui",
  "title": "Aurora Number Input",
  "author": "jmagar <https://github.com/jmagar>",
  "description": "Numeric stepper input with decrement and increment controls for tuning settings.",
  "dependencies": [
    "lucide-react@^0.487.0"
  ],
  "registryDependencies": [
    "aurora-tokens",
    "aurora-button",
    "aurora-input"
  ],
  "files": [
    {
      "path": "registry/aurora/ui/number-input.tsx",
      "content": "\"use client\"\n\nimport * as React from \"react\"\nimport { Minus, Plus } from \"lucide-react\"\nimport { Button } from \"./button\"\nimport { Input } from \"./input\"\n\nexport interface NumberInputProps\n  extends Omit<React.InputHTMLAttributes<HTMLInputElement>, \"type\" | \"value\" | \"defaultValue\" | \"onChange\"> {\n  value?: number\n  defaultValue?: number\n  min?: number\n  max?: number\n  step?: number\n  onValueChange?: (value: number) => void\n}\n\nconst NumberInput = React.forwardRef<HTMLInputElement, NumberInputProps>(\n  ({ value, defaultValue = 0, min, max, step = 1, onValueChange, ...props }, ref) => {\n    const controlled = value !== undefined\n    const [internalValue, setInternalValue] = React.useState(defaultValue)\n    const current = controlled ? value : internalValue\n\n    function clamp(next: number) {\n      if (min !== undefined && next < min) return min\n      if (max !== undefined && next > max) return max\n      return next\n    }\n\n    function commit(next: number) {\n      const clamped = clamp(next)\n      if (!controlled) setInternalValue(clamped)\n      onValueChange?.(clamped)\n    }\n\n    return (\n      <div className=\"inline-grid w-full grid-cols-[32px_minmax(0,1fr)_32px] items-center gap-2\">\n        <Button\n          type=\"button\"\n          variant=\"neutral\"\n          size=\"sm\"\n          aria-label=\"Decrease value\"\n          onClick={() => commit(current - step)}\n          disabled={props.disabled || (min !== undefined && current <= min)}\n          style={{ width: 32, padding: 0 }}\n        >\n          <Minus className=\"size-3.5\" aria-hidden />\n        </Button>\n        <Input\n          ref={ref}\n          type=\"number\"\n          value={current}\n          min={min}\n          max={max}\n          step={step}\n          onChange={(event) => commit(Number(event.target.value))}\n          {...props}\n        />\n        <Button\n          type=\"button\"\n          variant=\"neutral\"\n          size=\"sm\"\n          aria-label=\"Increase value\"\n          onClick={() => commit(current + step)}\n          disabled={props.disabled || (max !== undefined && current >= max)}\n          style={{ width: 32, padding: 0 }}\n        >\n          <Plus className=\"size-3.5\" aria-hidden />\n        </Button>\n      </div>\n    )\n  }\n)\nNumberInput.displayName = \"NumberInput\"\n\nexport { NumberInput }\nexport default NumberInput\n",
      "type": "registry:ui",
      "target": "@ui/aurora/number-input.tsx"
    }
  ],
  "meta": {
    "namespace": "@aurora",
    "style": "aurora",
    "family": "ui",
    "requiresTokens": true,
    "sourcePath": "registry/aurora/ui/number-input.tsx",
    "installTarget": "@ui/aurora/number-input.tsx"
  },
  "docs": "Aurora component that expects `aurora-tokens` to be installed first.\n\nDefault install target: `@ui/aurora/number-input.tsx`.\n\nRegistry dependencies: `aurora-tokens`, `aurora-button`, `aurora-input`.",
  "categories": [
