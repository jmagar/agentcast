    section: "actions",
    shortcut: ["⌘", "N"],
    icon: <ZapIcon />,
  },
  {
    id: "a2",
    label: "Search files",
    description: "Search across your project",
    section: "actions",
    shortcut: ["⌘", "F"],
    icon: <ZapIcon />,
  },
  {
    id: "a3",
    label: "Clear conversation",
    description: "Wipe current context",
    section: "actions",
    shortcut: ["⌘", "⇧", "K"],
    icon: <ZapIcon />,
  },
  {
    id: "s1",
    label: "Code review",
    description: "AI-powered code reviewer",
    section: "skills",
    icon: <StarIcon />,
  },
  {
    id: "s2",
    label: "Security review",
