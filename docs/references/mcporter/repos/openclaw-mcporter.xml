        'mcporter call linear.create_issue(title: "Bug", teamId: "ENG")',
      ],
      { maxExamples: 2, maxLength: 60 }
    );
    expect(lines).toHaveLength(2);
    expect(lines[0]).toContain('...');
    expect(lines[1]).toContain('create_issue(');
