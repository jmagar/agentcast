import { handleResource } from '../src/cli/resource-command.js';
import type { Runtime } from '../src/runtime.js';

function createRuntime(): Runtime & {
  listResources: ReturnType<typeof vi.fn>;
  readResource: ReturnType<typeof vi.fn>;
} {
  return {
