      fs.mkdirSync(tempConfigDir, { recursive: true });
      fs.copyFileSync(path.join(FIXTURE_ROOT, 'config', 'mcporter.json'), path.join(tempConfigDir, 'mcporter.json'));

      const servers = await loadServerDefinitions({
