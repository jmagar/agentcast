    // Background task used some tokens
    backgroundTaskResult.usage.input_tokens = 100;
    backgroundTaskResult.usage.output_tokens = 50;

    const promptResult = createResultMessage({
      subtype: "success",
      stop_reason: null,
      is_error: false,
